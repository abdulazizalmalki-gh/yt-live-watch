while True:
    frames = sorted(FRAMES_DIR.glob("*.jpg"))

    for frame in frames:
        if frame in seen:
            safe_delete(frame)
            continue

        seen.add(frame)
        should_delete = True

        try:
            size1 = frame.stat().st_size
            time.sleep(0.2)
            size2 = frame.stat().st_size

            if size1 != size2 or size2 == 0:
                seen.discard(frame)
                should_delete = False
                continue

            current_hash = avg_hash(frame)

            if last_hash is not None:
                diff = hamming(last_hash, current_hash)
                if diff < HASH_DIFF:
                    last_hash = current_hash
                    continue

            last_hash = current_hash

            result = ask_vlm(frame)

            if result and result.strip() != "SKIP":
                header = header_for_frame(frame)

                print(header, flush=True)
                print(result, flush=True)
                print("", flush=True)

                append_to_file(header)
                append_to_file(result)
                append_to_file("")

                memory.append(result.strip())
                memory[:] = memory[-25:]

        except Exception as e:
            print(f"[error] {frame.name}: {e}", flush=True)

        finally:
            if should_delete:
                safe_delete(frame)

    time.sleep(1)
PY

  cleanup() {
    echo
    echo "[info] Stopping..."

    jobs -p | xargs -r kill 2>/dev/null || true

    if [[ -n "${FRAMES_DIR:-}" && -d "${FRAMES_DIR:-}" ]]; then
      rm -rf "$FRAMES_DIR" 2>/dev/null || true
    fi

    if [[ -n "${RUN_RUNTIME_DIR:-}" && -d "${RUN_RUNTIME_DIR:-}" ]]; then
      rm -rf "$RUN_RUNTIME_DIR" 2>/dev/null || true
    fi
  }

  trap cleanup EXIT INT TERM

  rm -f "$FRAMES_DIR"/*.jpg 2>/dev/null || true

  echo "[info] Starting frame capture..."

  if command -v streamlink >/dev/null 2>&1; then
    streamlink --stdout "$URL" "$QUALITY" \
      | ffmpeg -hide_banner -loglevel warning \
          -i pipe:0 \
          -vf "fps=$FPS,scale=$WIDTH:-1" \
          -q:v 3 \
          "$FRAMES_DIR/frame_%08d.jpg" &
  else
    STREAM_URL="$(yt-dlp -f "best[height<=720]/best" -g "$URL" | head -n 1)"

    ffmpeg -hide_banner -loglevel warning \
      -i "$STREAM_URL" \
      -vf "fps=$FPS,scale=$WIDTH:-1" \
      -q:v 3 \
      "$FRAMES_DIR/frame_%08d.jpg" &
  fi

  CAPTURE_PID=$!

  echo "[info] Capture PID: $CAPTURE_PID"
  echo "[info] Starting analyzer..."
  echo

  export FRAMES_DIR OUTPUT_FILE VLM_URL VLM_MODEL HASH_DIFF MAX_TOKENS
  export ANALYSIS_INSTRUCTION="$custom_instruction"
  export FPS VIDEO_TITLE="$VIDEO_TITLE_LOCAL" VIDEO_URL="$URL" VIDEO_KEY="$VIDEO_KEY_LOCAL"
  export RUN_ID="$RUN_ID_LOCAL" VIDEO_LIVE_STATUS="$LIVE_STATUS_LOCAL" HEADER_MODE="$HEADER_MODE_LOCAL"
  export FRAME_INTERVAL

  python3 "$PY_APP"
}

